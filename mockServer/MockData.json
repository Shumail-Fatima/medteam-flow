      "appointmentId": "apt_1753790122836",
      "date": "2025-07-29T11:58:10.669Z",
      "symptoms": [
        "Localized pain in the lower back",
        "especially after prolonged sitting",
        "muscle tightness",
        "mild limitation in bending forward."
      ],
      "diagnosis": "Lumbar strain – likely due to poor posture and overuse. No neurological signs. Conservative treatment advised.",
      "notes": "Patient complains of lower back pain that has developed gradually over the last week. The pain is dull, increases after prolonged sitting, and is relieved by movement. No radiating pain or numbness. Physical exam reveals tightness in lumbar paraspinal muscles and mild tenderness over L3-L5 region. No red flags observed. Advised posture correction, ergonomic adjustments, and physiotherapy focusing on core strengthening and stretching.",
      "prescriptions": [
        {
          "id": "rx_1753790290669_0",
          "medication": "Paracetamol",
          "dosage": "500 mg",
          "frequency": "Thrice daily",
          "duration": "3 days",
          "instructions": "Take after meals; continue only if pain persists beyond 3 days."
        }
      ],
      "followUpRequired": false,
      "createdAt": "2025-07-29T11:58:10.669Z",
      "status": "completed"
    },
    {
      "id": "cons_1753790528507",
      "patientId": "patient_3",
      "patientName": "Robert Johnson",
      "doctorId": "5",
      "doctorName": "Dr. James Thompson",
      "appointmentId": "apt_1753790153151",
      "date": "2025-07-29T12:02:08.507Z",
      "symptoms": [
        "Knee pain during stair climbing and squatting",
        "occasional clicking sound",
        "minor instability while walking downhill."
      ],
      "diagnosis": "Patellofemoral pain syndrome (Runner’s knee) – overuse injury common in active individuals.",
      "notes": "The patient is physically active and reports anterior knee pain aggravated by stairs, squats, and prolonged sitting. No history of trauma. On examination, there is slight patellar maltracking and tenderness around the patella. No swelling or effusion. Functional tests indicate weak quadriceps and tight hamstrings. Diagnosed with patellofemoral pain syndrome. Advised activity modification, quadriceps strengthening, and hamstring stretching exercises. No surgical intervention required.",
      "prescriptions": [
        {
          "id": "rx_1753790528507_0",
          "medication": "Naproxen",
          "dosage": "250 mg",
          "frequency": " Twice daily after meals",
          "duration": "7 days",
          "instructions": "Take with food; avoid if gastric discomfort occurs."
        }
      ],
      "followUpRequired": false,
      "createdAt": "2025-07-29T12:02:08.507Z",
      "status": "completed"
    }
